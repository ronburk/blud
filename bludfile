-- bludfile for building/testing blud
CC  = gcc 
CXX = g++
CFLAGS = -g
LUAJIT_LDFLAGS ?= -L./luajit/src -lluajit
LDFLAGS = $(LUAJIT_LDFLAGS)
LUAJIT_CFLAGS ?= -I/usr/local/include/luajit-2.1
CFLAGS  = $(CFLAGS) -Wall -Wextra -fmax-errors=2 $(LUAJIT_CFLAGS)

all : blud test

test :TEST: test[0-9][0-9][0-9][0-9]
    ./blud -f $<

debug release :BUILD:
debug: CFLAGS += -g

SRCS = blud.c bludlua.c oslinux.c

blud :: $(SRCS)

-- use cstr to convert Lua source into a C string, they all will reside in bludlua.c
STRFILES = *.lua builtin.blud
bludlua.c :  cstr $(STRFILES)
    $(OWD)/cstr $(STRFILES) >$@

-- build cstr utility (writen in C++)
cstr :: cstr.cpp
