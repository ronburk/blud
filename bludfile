-- variables are scoped, from the environment down to individual instances of atoms
-- attributes are attached to atoms or rules

-- the basics: assign an attribute to an atom:
-- This is done by putting the attribute on the left

name: .BINARYATOM .ALSO
.BINARYATOM: a b c d

-- the basics: assign an attribute value to an atom

name: .ONLYONEATOM = some stuff in make style
name: .ONLYONEATOM = { true --[[ final expression of Lua block ]] }
a b c : .ONLYONEATOM = { false }

-- the basics assign a variable, which is always a string

name : VAR = a b c d

-- let's say that Lua inside make rules is identified by {}

{this.PHONY = true} : a b c d

-- assign to a target attribute
debug:virtual={true}
debug:virtual=true
debug:OWD=debug

debug : a b
-- is same as:
debug:: 

-- debugging output
debug :
      {
      
      }
