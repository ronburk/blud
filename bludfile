-- bludfile for building/testing blud

CC = gcc
CFLAGS = -g

-- all : macro blud
all : macro


FOO = 1
FOO = $(FOO)2$(FOO)
FEE = $(FOO)
FEE = $(FEE)3$(FEE)

macro :
    echo $(FOO) and $(FEE)

debug release :BUILD:

test :TEST:
    $ BLUD_SWD := $(BLUD_CWD)/$@
    $ BLUD_CWD := $(BLUD_OWD)

test: test*

blud :: blud.c

