-- bludfile for building/testing blud

CC  = gcc
CXX = g++
CFLAGS = -g
LDFLAGS = -L./luajit/src -lluajit
CFLAGS  = -Wall -Wextra -fmax-errors=2 -I/usr/local/include/luajit-2.1



all : blud test

test :TEST:
    ./blud -f $<


test%.out : test/test%.blud
  echo "blud -f $@ -o $<"

test :: test/test*.blud
    echo "Finished running tests"


debug release :BUILD:


blud :: *.c

-- use cstr to convert Lua source into a C string
STRFILES = blud.lua builtin.blud
bludlua.c : $(STRFILES) cstr
    $(OWD)/cstr $(STRFILES) >$@

-- build cstr utility (writen in C++)
cstr :: cstr.cpp
