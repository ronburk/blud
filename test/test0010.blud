INNER = inner
OUTER = $(INNER)tail

all: first second first
    echo $@
    echo $<
    echo $^
    echo $(BLUD_SCOPE_ENV)
    echo $(OUTER)

first:
    touch $@

second:
    touch $@


PRIVATE_FALLBACK = outer

private_parent: private PRIVATE_ONLY = parent
private_parent: private PRIVATE_FALLBACK = parent
private_parent: PUBLIC_INHERIT = parent
private_parent: private_child
    echo parent:$(PRIVATE_ONLY):$(PRIVATE_FALLBACK):$(PUBLIC_INHERIT)

private_child:
    echo child:$(PRIVATE_ONLY):$(PRIVATE_FALLBACK):$(PUBLIC_INHERIT)
