blud = {
    Macro = {
        expand_tokens = function(_, parts)
            assert(type(parts) == "table")
            return table.concat(parts)
        end,
    },
    assert = assert,
    error = error,
}

local Scope = assert(loadfile("scope.lua"))()

local scope = Scope:new(nil, "test")
scope:set("NAME", "literal")
local parts = scope:get_parts("NAME")
assert(type(parts) == "table")
assert(#parts == 1 and parts[1] == "literal")
assert(type(scope.variables.NAME) == "table")

scope:set_boolean(".JUST_PRINT", true)
assert(type(scope:get_parts(".JUST_PRINT")) == "table")
assert(scope:get_boolean(".JUST_PRINT") == true)
scope:set_boolean(".JUST_PRINT", false)
assert(scope:get_boolean(".JUST_PRINT") == false)

local environment_parts = Scope.environment:get_parts("BLUD_SCOPE_ENV")
assert(type(environment_parts) == "table")
assert(#environment_parts == 1 and environment_parts[1] == "environment")

local target = {
    BOUND_NAME = "target",
    PREREQUISITES = {
        { BOUND_NAME = "first" },
        { BOUND_NAME = "second" },
        { BOUND_NAME = "first" },
    },
}
local target_scope = Scope:new_target_scope(target)

local target_parts = target_scope:get_parts("@")
assert(type(target_parts) == "table")
assert(#target_parts == 1 and target_parts[1] == "target")

local first_parts = target_scope:get_parts("<")
assert(type(first_parts) == "table")
assert(#first_parts == 1 and first_parts[1] == "first")

local prerequisites_parts = target_scope:get_parts("^")
assert(type(prerequisites_parts) == "table")
assert(#prerequisites_parts == 1)
assert(prerequisites_parts[1] == "first second ")


local outer_scope = Scope:new(nil, "outer")
outer_scope:set("FALLBACK", "outer")
outer_scope:set("PUBLIC", "outer")

local parent_target = { BOUND_NAME = "parent", PREREQUISITES = {} }
local parent_scope = Scope:new_target_scope(parent_target)
parent_scope.parent = outer_scope
parent_scope:set("PUBLIC", "parent")
parent_scope:set("SECRET", { "parent", private = true })
parent_scope:set("FALLBACK", { "parent", private = true })

assert(parent_scope:get_text("SECRET") == "parent")
assert(parent_scope:get_text("FALLBACK") == "parent")

local child_target = { BOUND_NAME = "child", PREREQUISITES = {} }
local child_scope = Scope:new_target_scope(child_target)
child_scope:set_target_parent(parent_scope)
assert(child_scope:get_text("PUBLIC") == "parent")
assert(child_scope:get_parts("SECRET") == nil)
assert(child_scope:get_text("FALLBACK") == "outer")

child_scope:set_boolean("PRIVATE_BOOL", true, true)
assert(child_scope.variables.PRIVATE_BOOL.private == true)
